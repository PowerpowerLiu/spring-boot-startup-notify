<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.springboot-notify</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <!-- Replace with the actual path to notify.sh -->
        <string>/path/to/spring-boot-startup-notify/notify.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <!-- Restart automatically if the script exits -->
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/springboot-notify.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/springboot-notify.log</string>
</dict>
</plist>
